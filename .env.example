# Copy to .env and fill in your API key.
# train.py loads this file at startup and forwards variables to the Claude CLI
# subprocess. Shell exports (`export FOO=bar`) override these values.

# === Required ===

# Your provider's API key.
ANTHROPIC_API_KEY=replace-with-your-api-key

# === Recommended ===

# Disable Claude Code's built-in tool search to reduce per-round token cost.
ENABLE_TOOL_SEARCH=false

# === Provider configuration ===
# Pick ONE provider block below (uncomment the lines for the one you use).
# Leave all blocks commented to use the official Anthropic API.

# --- Provider: Kimi (Moonshot) ---
# ANTHROPIC_BASE_URL=https://api.kimi.com/coding/

# --- Provider: Mimo (Xiaomi) ---
# ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# ANTHROPIC_DEFAULT_OPUS_MODEL=mimo-v2.5-pro
# ANTHROPIC_DEFAULT_SONNET_MODEL=mimo-v2.5-pro
# ANTHROPIC_DEFAULT_HAIKU_MODEL=mimo-v2.5-pro

# --- Provider: official Anthropic API ---
# (leave ANTHROPIC_BASE_URL unset; Claude CLI defaults to the official endpoint)
